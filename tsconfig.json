{
	"compilerOptions": {
		"types": ["node"],
		"module": "commonjs",
		"target": "es2019",
		"lib": ["ES2019"],
		"outDir": "out",
		"sourceMap": true,
		"esModuleInterop": true,
		"rootDir": "src",
		"strictNullChecks": false,
		"noImplicitAny": false
	},
	"exclude": [
		"node_modules",
		".vscode-test",
	]
}